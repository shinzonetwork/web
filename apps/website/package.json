{
  "name": "shinzo-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:staging": "wrangler dev --env staging --port 3000",
    "build": "next build",
    "build:open": "opennextjs-cloudflare build",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:app": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "deploy:database": "NODE_ENV=production CLOUDFLARE_ENV=$CLOUDFLARE_ENV payload migrate && pnpm seed:chains && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "payload generate:types",
    "lint": "eslint",
    "payload": "payload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "seed:chains": "pnpx tsx data/seed-chains.ts",
    "start": "next start"
  },
  "dependencies": {
    "@payloadcms/db-d1-sqlite": "3.84.1",
    "@payloadcms/email-resend": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-r2": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@shinzo/ui": "workspace:*",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.100.10",
    "@wagmi/connectors": "^7.1.5",
    "@wagmi/core": "^3.3.1",
    "@walletconnect/ethereum-provider": "^2.23.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "17.4.2",
    "graphql": "^16.14.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-plausible": "^3.12.5",
    "payload": "3.84.1",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "viem": "~2.44.4",
    "wagmi": "^2.19.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shinzo/eslint-config": "workspace:*",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "prettier": "^3.8.1",
    "tw-animate-css": "^1.4.0"
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  }
}
