# RPC URL for the Shinzo network
# This should point to a Shinzohub RPC endpoint
NEXT_PUBLIC_RPC_URL=

# Server-only: used by POST /api/shinzohub/generators/assert
INDEXER_ASSERTION_PRIVATE_KEY=
# Optional override; defaults to SHINZOHUB_COMET_RPC_URL / develop comet RPC
INDEXER_ASSERTION_RPC_ENDPOINT=
# Optional CometBFT / Cosmos REST overrides for ShinzoHub queries
SHINZOHUB_COMET_RPC_URL=
SHINZOHUB_COSMOS_REST_URL=
