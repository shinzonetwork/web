# EVM RPC URL for the Shinzo network (defaults to http://testnet.shinzo.network:8545 in development)
NEXT_PUBLIC_RPC_URL=

# Server-only: used by POST /api/shinzohub/generators/assert
INDEXER_ASSERTION_PRIVATE_KEY=
# Optional override; defaults to SHINZOHUB_COMET_RPC_URL / testnet comet RPC
INDEXER_ASSERTION_RPC_ENDPOINT=
# Optional CometBFT / Cosmos REST overrides (default to testnet.shinzo.network:26657 and :1317)
SHINZOHUB_COMET_RPC_URL=
SHINZOHUB_COSMOS_REST_URL=
