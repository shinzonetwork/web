{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"main": ".open-next/worker.js",
	"name": "shinzo-explorer",
	"compatibility_date": "2026-01-04",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"keep_vars": true,
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"env": {
		"internal": {
			"name": "shinzo-explorer-internal"
		}
	}
}
