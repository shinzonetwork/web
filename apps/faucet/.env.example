# get it from https://www.google.com/recaptcha/admin/create
# do not forget to set testing url in allowlist of recaptcha dashboard https://console.cloud.google.com/security/recaptcha
# or in https://console.cloud.google.com/security/recaptcha/{VITE_RECAPTCHA_SITE_KEY}/overview
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ShinzoHub block explorer used for frontend transaction links
VITE_SHINZOHUB_EXPLORER_URL=https://explorer.shinzo.network/shinzohub

# ShinzoHub environment used by the worker: testnet | internal | devnet | local
SHINZOHUB_CHAIN=testnet

# private key of account to send $SHN tokens from
FAUCET_PRIVATE_KEY=
