{
  "options": {
    "path": ["node_modules"],
    "initialMemory": 4,
    "use": ["abort=lib/abort/abort"]
  },
  "targets": {
    "erc20-transfers": {
      "outFile": "erc20-transfers/lens.wasm",
      "optimizeLevel": 3,
      "shrinkLevel": 0,
      "converge": false,
      "noAssert": false
    },
    "erc20-account-balances": {
      "outFile": "erc20-account-balances/lens.wasm",
      "optimizeLevel": 3,
      "shrinkLevel": 0,
      "converge": false,
      "noAssert": false
    }
  }
}
